<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <!-- 顶部标题区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="车辆控制"
                        android:textColor="#1F2933"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedVehicle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="未选择车辆"
                        android:textColor="#7B8794"
                        android:textSize="14sp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/ivRefreshVehicleState"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_icon_circle"
                    android:contentDescription="刷新车辆状态"
                    android:padding="10dp"
                    android:src="@drawable/ic_refresh_24"
                    android:tint="#23C6A8" />

            </LinearLayout>

            <!-- 车辆状态总览卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_control_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="实时状态"
                    android:textColor="#1F2933"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVehicleOnlineStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_status_chip"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="10dp"
                    android:text="在线状态：-"
                    android:textColor="#159A86"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvVehicleLockStatus"
                        android:layout_width="0dp"
                        android:layout_height="74dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_state_item"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="车锁状态：-"
                        android:textColor="#1F2933"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvVehicleEngineStatus"
                        android:layout_width="0dp"
                        android:layout_height="74dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_state_item"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="发动机：-"
                        android:textColor="#1F2933"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvVehicleHvacStatus"
                        android:layout_width="0dp"
                        android:layout_height="74dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_state_item"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="空调：-"
                        android:textColor="#1F2933"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvVehicleWindowStatus"
                        android:layout_width="0dp"
                        android:layout_height="74dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_state_item"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="车窗：-"
                        android:textColor="#1F2933"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 操作提示 -->
            <TextView
                android:id="@+id/tvControlHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_hint_card"
                android:padding="14dp"
                android:text="请选择需要执行的远程控制操作"
                android:textColor="#5F6C7B"
                android:textSize="14sp" />

            <!-- 控制按钮区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_control_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="远程控制"
                    android:textColor="#1F2933"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- 车锁 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLockOn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_primary"
                        android:text="上锁"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnLockOff"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="解锁"
                        android:textAllCaps="false"
                        android:textColor="#159A86"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 空调 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnHvacOn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_primary"
                        android:text="开启空调"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnHvacOff"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="关闭空调"
                        android:textAllCaps="false"
                        android:textColor="#159A86"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 车窗 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnWindowOpen"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_primary"
                        android:text="打开车窗"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnWindowClose"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="关闭车窗"
                        android:textAllCaps="false"
                        android:textColor="#159A86"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 发动机 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnEngineOn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_danger"
                        android:text="启动发动机"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnEngineOff"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="关闭发动机"
                        android:textAllCaps="false"
                        android:textColor="#159A86"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnStatusQuery"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button_dark"
                    android:text="查询车辆状态"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 最近操作结果 -->
            <TextView
                android:id="@+id/tvLatestActionResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_result_card"
                android:padding="16dp"
                android:text="最近操作：暂无"
                android:textColor="#1F2933"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>