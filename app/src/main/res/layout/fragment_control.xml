<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="实时状态"
                android:textColor="#1F2933"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVehicleOnlineStatus"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:background="@drawable/bg_status_pending"
                android:gravity="center"
                android:minWidth="92dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="-"
                android:textColor="#7B8794"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivRefreshVehicleState"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_icon_circle"
                android:contentDescription="刷新"
                android:padding="10dp"
                android:src="@drawable/ic_refresh_24"
                android:tint="#23C6A8" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedVehicle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未选择车辆"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvControlHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_hint_card"
            android:gravity="center"
            android:minHeight="62dp"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:text="-"
            android:textColor="#5F6C7B"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:background="@drawable/bg_control_card"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <!-- 车锁 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="wrap_content"
                    android:text="车锁"
                    android:textColor="#1F2933"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVehicleLockStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-"
                    android:textColor="#5F6C7B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnLockOff"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="开"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnLockOn"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_button_danger"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="关"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEF3F7" />

            <!-- 发动机 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="wrap_content"
                    android:text="发动机"
                    android:textColor="#1F2933"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVehicleEngineStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-"
                    android:textColor="#5F6C7B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnEngineOn"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="开"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnEngineOff"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_button_danger"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="关"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEF3F7" />

            <!-- 空调 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="wrap_content"
                    android:text="空调"
                    android:textColor="#1F2933"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVehicleHvacStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-"
                    android:textColor="#5F6C7B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnHvacOn"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="开"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnHvacOff"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_button_danger"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="关"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEF3F7" />

            <!-- 车窗 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="wrap_content"
                    android:text="车窗"
                    android:textColor="#1F2933"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVehicleWindowStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-"
                    android:textColor="#5F6C7B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnWindowOpen"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="开"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnWindowClose"
                    android:layout_width="54dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_button_danger"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="关"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnStatusQuery"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvLatestActionResult"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="-"
            android:visibility="gone" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>