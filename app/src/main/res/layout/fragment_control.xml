<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvSelectedVehicle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前车辆："
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="实时通道：未连接"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvRealtimeState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="最近收到的实时状态：-"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnPing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="发送 WebSocket ping" />

        <TextView
            android:id="@+id/tvControlSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="控制命令"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnLockOn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="开锁（LOCK_ON）" />

        <Button
            android:id="@+id/btnLockOff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="关锁（LOCK_OFF）" />

        <Button
            android:id="@+id/btnHvacOn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="打开空调（HVAC_ON）" />

        <Button
            android:id="@+id/btnHvacOff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="关闭空调（HVAC_OFF）" />

        <Button
            android:id="@+id/btnWindowOpen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="打开车窗（WINDOW_OPEN）" />

        <Button
            android:id="@+id/btnWindowClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="关闭车窗（WINDOW_CLOSE）" />

        <Button
            android:id="@+id/btnEngineOn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="启动发动机（ENGINE_ON）" />

        <Button
            android:id="@+id/btnEngineOff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="关闭发动机（ENGINE_OFF）" />

        <Button
            android:id="@+id/btnStatusQuery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="状态查询（STATUS_QUERY）" />

        <TextView
            android:id="@+id/tvResultSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="最近一条命令结果"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCommandId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="commandId：" />

        <TextView
            android:id="@+id/tvCommandType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="命令类型：" />

        <TextView
            android:id="@+id/tvCommandResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="命令结果：" />

        <TextView
            android:id="@+id/tvRequestTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="请求时间：" />

        <TextView
            android:id="@+id/tvResponseTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="响应时间：" />

        <Button
            android:id="@+id/btnRefreshResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="刷新最近命令结果" />

    </LinearLayout>
</ScrollView>