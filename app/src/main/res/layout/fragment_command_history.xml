<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_car_page"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="指令历史"
            android:textColor="@color/car_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="按照车辆与执行状态查看远程控制记录"
            android:textColor="@color/car_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvStateBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="14dp"
            android:text="状态提示"
            android:textColor="@color/car_text_primary"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_car_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvCurrentFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="车辆范围：当前车辆"
                android:textColor="@color/car_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvResultFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="状态筛选：全部"
                android:textColor="@color/car_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="当前显示 0 条 · 已加载 0 条"
                android:textColor="@color/car_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRefreshCurrent"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_car_primary_button"
                    android:text="当前车辆"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Space android:layout_width="12dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnLoadAll"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_car_secondary_button"
                    android:text="全部历史"
                    android:textAllCaps="false"
                    android:textColor="@color/car_text_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnFilterAll"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_car_soft_button"
                    android:text="全部"
                    android:textAllCaps="false"
                    android:textColor="@color/car_primary_dark"
                    android:textStyle="bold" />

                <Space android:layout_width="8dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnFilterSuccess"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_car_soft_button"
                    android:text="成功"
                    android:textAllCaps="false"
                    android:textColor="@color/car_primary_dark"
                    android:textStyle="bold" />

                <Space android:layout_width="8dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnFilterFailed"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_car_secondary_button"
                    android:text="失败"
                    android:textAllCaps="false"
                    android:textColor="@color/car_text_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnFilterPending"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_car_secondary_button"
                android:text="进行中"
                android:textAllCaps="false"
                android:textColor="@color/car_text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/historyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
