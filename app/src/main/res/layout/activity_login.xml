<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/loginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4A540"
    android:fitsSystemWindows="true"
    tools:context=".ui.auth.login.LoginActivity">

    <!-- 上方整块车辆图片区域：图片文件请放在 res/drawable/bg_login_car.jpg -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLoginImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="34dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/formContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#00000000"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivLoginCar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="登录页车辆背景图"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_login_car" />

    </com.google.android.material.card.MaterialCardView>

    <!-- 表单区域：默认密码登录，可切换到短信验证码登录 -->
    <LinearLayout
        android:id="@+id/formContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="38dp"
        android:layout_marginEnd="38dp"
        android:layout_marginBottom="34dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 密码登录输入区 -->
        <LinearLayout
            android:id="@+id/layoutPasswordLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/etAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_login_input_underline"
                android:hint="账号"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:singleLine="true"
                android:textColor="@color/car_text_primary"
                android:textColorHint="#7A4C22"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/layoutPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_login_input_underline"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="密码"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:paddingStart="0dp"
                    android:paddingEnd="8dp"
                    android:singleLine="true"
                    android:textColor="@color/car_text_primary"
                    android:textColorHint="#7A4C22"
                    android:textSize="16sp" />

                <!-- 眼睛按钮：无圆圈背景，显示时眼睛睁开，隐藏时眼睛闭合 -->
                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="显示或隐藏密码"
                    android:padding="7dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_eye_closed_24"
                    app:tint="#2C2A26" />

                <!-- 保留旧 id，避免你原代码里如果还引用 tvTogglePassword 时报找不到。实际不显示。 -->
                <TextView
                    android:id="@+id/tvTogglePassword"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutRememberOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbRememberPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/selector_login_checkbox"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text=" 记住密码"
                    android:textColor="#2C2A26"
                    android:textSize="14sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <CheckBox
                    android:id="@+id/cbAutoLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:button="@drawable/selector_login_checkbox"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text=" 自动登录"
                    android:textColor="#2C2A26"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPasswordLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvForgetPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="忘记密码"
                    android:textColor="#2C2A26"
                    android:textSize="15sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvGoRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="注册账号"
                    android:textColor="#2C2A26"
                    android:textSize="15sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 短信验证码登录输入区 -->
        <LinearLayout
            android:id="@+id/layoutSmsLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_login_input_underline"
                android:hint="手机号"
                android:imeOptions="actionNext"
                android:inputType="phone"
                android:maxLength="11"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:singleLine="true"
                android:textColor="@color/car_text_primary"
                android:textColorHint="#7A4C22"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/layoutSmsCodeInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_login_input_underline"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etSmsCode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="验证码"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLength="6"
                    android:paddingStart="0dp"
                    android:paddingEnd="8dp"
                    android:singleLine="true"
                    android:textColor="@color/car_text_primary"
                    android:textColorHint="#7A4C22"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSendLoginCode"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_login_sms_code_button"
                    android:gravity="center"
                    android:minWidth="92dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="获取验证码"
                    android:textColor="#6B69D6"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_login_primary_button"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:text="登录"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:indeterminateTint="#6B69D6"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvSwitchLoginMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:includeFontPadding="false"
            android:text="手机短信登录  >"
            android:textColor="#2C2A26"
            android:textSize="15sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
