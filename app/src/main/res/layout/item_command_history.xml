<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootHistoryItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_surface_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOCK_ON"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="结果：SUCCESS"
        android:textColor="#E7ECFA"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvVehicleId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="车辆：v001"
        android:textColor="#E7ECFA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvCommandId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="commandId：xxxx"
        android:textColor="#C8D2EC"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="3dp"
        android:text="请求：2026-01-01 10:00:00&#10;响应：2026-01-01 10:00:02"
        android:textColor="#C8D2EC"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvDetailHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="点击查看完整请求/响应详情"
        android:textColor="#AFC2FF"
        android:textSize="13sp" />

</LinearLayout>