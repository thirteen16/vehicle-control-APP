<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootHistoryItem"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_history_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">

    <TextView
        android:id="@+id/tvType"
        android:layout_width="96dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="关闭车锁"
        android:textColor="@color/car_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="05-15 23:12"
        android:textColor="@color/car_text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvResultBadge"
        android:layout_width="58dp"
        android:layout_height="30dp"
        android:gravity="center"
        android:text="成功"
        android:textColor="@color/car_primary_dark"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvVehicleId"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:text="-"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvDetailHint"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:text="-"
        android:visibility="gone" />

</LinearLayout>