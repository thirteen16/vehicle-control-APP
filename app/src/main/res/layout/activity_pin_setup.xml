<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_start"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="34dp"
        android:paddingEnd="24dp"
        android:paddingBottom="30dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:background="@drawable/bg_pin_back_chip"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="← 返回"
            android:textColor="@color/car_primary_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Vehicle Security"
            android:textColor="@color/car_primary_dark"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="设置 PIN"
            android:textColor="@color/car_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="首次使用远程控制前，请设置 6 位数字 PIN，并通过手机验证码确认。"
            android:textColor="@color/car_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_pin_card"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvStepLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请输入新的 6 位 PIN"
                android:textColor="@color/car_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="PIN 仅允许 6 位数字，用于执行远程控制前的本地安全验证。"
                android:textColor="@color/car_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/pinBox1"
                    style="@style/PinBoxStyle" />

                <TextView
                    android:id="@+id/pinBox2"
                    style="@style/PinBoxStyle" />

                <TextView
                    android:id="@+id/pinBox3"
                    style="@style/PinBoxStyle" />

                <TextView
                    android:id="@+id/pinBox4"
                    style="@style/PinBoxStyle" />

                <TextView
                    android:id="@+id/pinBox5"
                    style="@style/PinBoxStyle" />

                <TextView
                    android:id="@+id/pinBox6"
                    style="@style/PinBoxStyle" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/codeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_pin_card"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机验证码"
                android:textColor="@color/car_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPhoneCodeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="验证码会发送到当前账号绑定手机号，并显示在模拟车机管理台。"
                android:textColor="@color/car_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etPhoneCode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_auth_light_input"
                    android:hint="请输入6位验证码"
                    android:inputType="number"
                    android:maxLength="6"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/car_text_primary"
                    android:textColorHint="@color/car_text_hint"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnSendPinCode"
                    android:layout_width="116dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_pin_secondary_button"
                    android:text="发送验证码"
                    android:textAllCaps="false"
                    android:textColor="@color/car_primary_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_pin_keyboard_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout style="@style/PinKeyboardRowStyle">

                <Button
                    android:id="@+id/btnKey1"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="1" />

                <Button
                    android:id="@+id/btnKey2"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="2" />

                <Button
                    android:id="@+id/btnKey3"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="3" />
            </LinearLayout>

            <LinearLayout style="@style/PinKeyboardRowStyle">

                <Button
                    android:id="@+id/btnKey4"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="4" />

                <Button
                    android:id="@+id/btnKey5"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="5" />

                <Button
                    android:id="@+id/btnKey6"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="6" />
            </LinearLayout>

            <LinearLayout style="@style/PinKeyboardRowStyle">

                <Button
                    android:id="@+id/btnKey7"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="7" />

                <Button
                    android:id="@+id/btnKey8"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="8" />

                <Button
                    android:id="@+id/btnKey9"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="9" />
            </LinearLayout>

            <LinearLayout style="@style/PinKeyboardRowStyle">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_margin="6dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btnKey0"
                    style="@style/PinKeyboardButtonStyle"
                    android:text="0" />

                <Button
                    android:id="@+id/btnKeyDelete"
                    style="@style/PinKeyboardDeleteButtonStyle"
                    android:text="⌫" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnSavePin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_pin_primary_button"
            android:text="下一步"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnClearPin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_pin_danger_button"
            android:text="清除 PIN"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>