<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_start"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="112dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="我的"
            android:textColor="@color/car_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="管理账号、安全验证与系统设置"
            android:textColor="@color/car_text_secondary"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- 用户信息卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_profile_header_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_profile_avatar_circle"
                    android:gravity="center"
                    android:text="我"
                    android:textColor="@color/car_primary_dark"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未设置昵称"
                        android:textColor="@color/car_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="用户名：-"
                        android:textColor="@color/car_text_secondary"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_profile_info_chip"
                android:padding="13dp"
                android:text="手机号：-"
                android:textColor="@color/car_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSelectedVehicle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_profile_info_chip"
                android:padding="13dp"
                android:text="当前车辆：未选择"
                android:textColor="@color/car_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPinStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_profile_info_chip"
                android:padding="13dp"
                android:text="PIN 安全验证：未开启"
                android:textColor="@color/car_primary_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 资料与安全卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_profile_section_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="资料与安全"
                android:textColor="@color/car_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="可在这里更新个人资料、手机号和安全验证设置"
                android:textColor="@color/car_text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnEditNickname"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_profile_outline_button"
                android:text="修改昵称"
                android:textAllCaps="false"
                android:textColor="@color/car_primary_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnChangePhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_profile_outline_button"
                android:text="换绑手机号"
                android:textAllCaps="false"
                android:textColor="@color/car_primary_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnResetPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_profile_outline_button"
                android:text="重置密码"
                android:textAllCaps="false"
                android:textColor="@color/car_primary_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnManagePin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_profile_outline_button"
                android:text="管理 PIN 安全验证"
                android:textAllCaps="false"
                android:textColor="@color/car_primary_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnServerConfig"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_profile_outline_button"
                android:text="服务器配置"
                android:textAllCaps="false"
                android:textColor="@color/car_primary_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_profile_logout_button"
                android:text="退出登录"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>