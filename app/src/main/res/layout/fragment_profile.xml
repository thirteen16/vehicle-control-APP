<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_start"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="14dp">

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- 顶部用户信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/bg_profile_header_card"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户昵称"
                android:textColor="@color/car_text_primary"
                android:textSize="31sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPinStatus"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_status_failed"
                android:gravity="center"
                android:minWidth="128dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="PIN验证：关闭"
                android:textColor="@color/danger_red"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:background="@drawable/bg_profile_avatar_circle"
            android:gravity="center"
            android:text="我"
            android:textColor="@color/car_primary_dark"
            android:textSize="36sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 隐藏信息，保留 id，避免旧逻辑出错 -->
    <TextView
        android:id="@+id/tvUsername"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:text="-"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvPhone"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:text="-"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSelectedVehicle"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:text="-"
        android:visibility="gone" />

    <!-- 功能列表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_profile_section_card"
        android:elevation="3dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnEditNickname"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:text="修改昵称"
            android:textAllCaps="false"
            android:textColor="@color/car_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_light" />

        <Button
            android:id="@+id/btnChangePhone"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:text="修改手机号"
            android:textAllCaps="false"
            android:textColor="@color/car_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_light" />

        <Button
            android:id="@+id/btnResetPassword"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:text="修改密码"
            android:textAllCaps="false"
            android:textColor="@color/car_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_light" />

        <Button
            android:id="@+id/btnManagePin"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:text="设置 PIN"
            android:textAllCaps="false"
            android:textColor="@color/car_text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

    </LinearLayout>

    <Button
        android:id="@+id/btnServerConfig"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="210dp"
        android:layout_height="52dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_profile_logout_button"
        android:text="退出登录"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold" />

</LinearLayout>