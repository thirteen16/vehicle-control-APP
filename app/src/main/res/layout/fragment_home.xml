<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard_page_gradient"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="智能车控主页"
            android:textColor="#F5F8FF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPageSubTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="未来感车联中枢，集中查看车辆与定位信息"
            android:textColor="#9FB0D2"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvStateBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="14dp"
            android:text="状态提示"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_dashboard_stat_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="车辆总数"
                android:textColor="#9FB0D2"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvVehicleCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="当前账号已绑定车辆数量"
                android:textColor="#7F91B8"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_dashboard_current_card"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前绑定车辆"
                        android:textColor="#AFC2FF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentVehicleName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="未绑定车辆"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentVehicleId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="vehicleId：-"
                        android:textColor="#A8B8D8"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivRefreshCurrent"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_dashboard_icon_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_popup_sync"
                    android:tint="#EAF1FF" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCurrentBrandModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="品牌 / 型号：- / -"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCurrentOnlineStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="在线状态：-"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCurrentLockStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="车锁状态：-"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCurrentEngineStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="发动机：-"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCurrentHvacStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="空调：-"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCurrentWindowStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="车窗：-"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCurrentMileage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="总里程：- km"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvCurrentFuelLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="油量：-%"
                android:textColor="#E7ECFA"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentUpdatedTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="更新时间：-"
                    android:textColor="#A8B8D8"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/ivCurrentLocation"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_dashboard_icon_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="#EAF1FF" />
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tvOtherVehicleTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="其他车辆 (0)"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEmptyOtherVehicles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="暂无其他车辆"
            android:textColor="#8EA0C4"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/otherVehicleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>