<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_car_page"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvStateBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:text="状态提示"
            android:textColor="@color/car_text_primary"
            android:textSize="14sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvVehicleCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_car_card"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:id="@+id/ivCurrentVehicleImage"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:adjustViewBounds="true"
                android:background="@color/card_light"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_login_car" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentVehicleName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未绑定车辆"
                    android:textColor="@color/car_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivRefreshCurrent"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_car_soft_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="9dp"
                    android:src="@android:drawable/ic_popup_sync"
                    android:tint="@color/car_primary_dark" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCurrentBrandModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="-"
                android:textColor="@color/car_text_secondary"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="在线/离线"
                        android:textColor="@color/car_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCurrentOnlineStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="-"
                        android:textColor="@color/car_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="油量"
                        android:textColor="@color/car_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCurrentFuelLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="-"
                        android:textColor="@color/car_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总里程"
                        android:textColor="@color/car_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCurrentMileage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="- km"
                        android:textColor="@color/car_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivCurrentLocation"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_car_soft_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="@color/car_primary_dark" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCurrentVehicleId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentLockStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentEngineStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentHvacStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentWindowStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentUpdatedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutOtherVehicleHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_car_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="10dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/tvOtherVehicleTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="其他绑定车辆"
                android:textColor="@color/car_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOtherVehicleCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="0"
                android:textColor="@color/car_text_secondary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ivToggleOtherVehicles"
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_car_soft_button"
                android:gravity="center"
                android:text=">"
                android:textColor="@color/car_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvEmptyOtherVehicles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_car_card"
            android:padding="16dp"
            android:text="暂无其他绑定车辆"
            android:textColor="@color/car_text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/otherVehicleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>