<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootVehicleCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_dashboard_vehicle_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvVehicleName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tesla Model 3"
        android:textColor="#FFFFFF"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvVehicleId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="vehicleId：v001"
        android:textColor="#A8B8D8"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvBrandModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="品牌 / 型号：Tesla / Model 3"
        android:textColor="#E7ECFA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvMileage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="总里程：12345 km"
        android:textColor="#E7ECFA"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="点击卡片可切换为当前车辆"
            android:textColor="#8EA0C4"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/ivLocation"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_dashboard_icon_circle"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_mylocation"
            android:tint="#EAF1FF" />
    </LinearLayout>

</LinearLayout>